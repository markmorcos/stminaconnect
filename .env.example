# =============================================================================
# St. Mina Connect — environment variables
# =============================================================================
# Copy this file to `.env.local` for local development. Never commit a real
# `.env*` file other than this example.
#
# Vars marked "unused until phase N" are listed here for forward compatibility
# so that scaffolding never has to scatter declarations across phases.
# Values may be left as-is (placeholder) until that phase activates them.
# =============================================================================

# -------------------------------------------------------------------
# Mobile client (read by Expo at build time — must use EXPO_PUBLIC_ prefix)
# -------------------------------------------------------------------

# Supabase (this phase)
# After `make dev-up`, the local Supabase CLI prints:
#   API URL:    http://127.0.0.1:54321
#   anon key:   eyJ...
# Copy those values here.
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key

# Mock vs real notification service (unused until phase 9 / 20)
# Allowed values: mock | real
EXPO_PUBLIC_NOTIFICATION_DISPATCHER=mock

# Default UI locale on first launch (unused until phase 5)
EXPO_PUBLIC_DEFAULT_LOCALE=en

# -------------------------------------------------------------------
# Server / Edge Functions (Supabase secrets, not bundled into the mobile app)
# -------------------------------------------------------------------

# Service-role key for Edge Functions
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Google Calendar service account JSON.
# Single-line JSON, consumed by the `sync-calendar-events` Edge Function.
# Setup: docs/google-calendar-setup.md.
# In hosted environments this is set via `supabase secrets set`, never
# committed. The example below is a placeholder.
GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON=

# Google Calendar ID watched for events.
# For private calendars this is a long string ending in
# `@group.calendar.google.com`; for primary calendars it is the email.
GOOGLE_CALENDAR_ID=

# Expo Push access token (unused until phase 20)
# Obtained from https://expo.dev/settings/access-tokens
EXPO_ACCESS_TOKEN=
