{
  "expo": {
    "name": "St. Mina Connect",
    "slug": "st-mina-connect",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/branding/icon-source.png",
    "scheme": "stminaconnect",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "tech.morcos.stminaconnect",
      "icon": "./assets/branding/icon-source.png"
    },
    "android": {
      "package": "tech.morcos.stminaconnect",
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/icon-foreground.png",
        "backgroundColor": "#8B1E2D"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-sqlite",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/branding/splash-light.png",
          "resizeMode": "contain",
          "backgroundColor": "#FBF8F4",
          "dark": {
            "image": "./assets/branding/splash-dark.png",
            "backgroundColor": "#15110E"
          }
        }
      ]
    ]
  }
}
