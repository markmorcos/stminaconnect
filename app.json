{
  "expo": {
    "name": "St. Mina Connect",
    "slug": "stminaconnect",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/branding/icon-source.png",
    "scheme": "stminaconnect",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stminaconnect",
      "icon": "./assets/branding/icon-source.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.stminaconnect",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/icon-foreground.png",
        "backgroundColor": "#8B1E2D"
      },
      "predictiveBackGestureEnabled": false
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-sqlite",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/branding/splash-light.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#FBF8F4",
          "dark": {
            "image": "./assets/branding/splash-dark.png",
            "backgroundColor": "#15110E"
          }
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "709cf095-c8d1-4a89-b897-ee734c8d8acd"
      }
    },
    "owner": "markmorcos"
  }
}
