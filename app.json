{
  "expo": {
    "name": "St. Mina Connect",
    "slug": "st-mina-connect",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icons/icon-placeholder.png",
    "scheme": "stminaconnect",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icons/splash-placeholder.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBF8F4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "tech.morcos.stminaconnect"
    },
    "android": {
      "package": "tech.morcos.stminaconnect",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/icon-placeholder.png",
        "backgroundColor": "#FBF8F4"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "plugins": ["expo-router", "expo-localization", "expo-sqlite", "expo-font"]
  }
}
